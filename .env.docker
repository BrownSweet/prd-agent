# =====================================================
# Docker 环境配置示例
# =====================================================
# 复制此文件为 .env 并填写实际值
# cp .env.docker .env

# =====================================================
# LLM 配置
# =====================================================
# 选择你的 LLM 提供商和模型

# DeepSeek (推荐)
LLM_MODEL=deepseek/deepseek-chat
LLM_API_KEY=sk-xxxxxxxxxxxxx
LLM_PROVIDER=deepseek

# 或者 OpenAI
# LLM_MODEL=openai/gpt-4
# LLM_API_KEY=sk-xxxxxxxxxxxxx
# LLM_PROVIDER=openai

# 或者 Ollama (本地)
# LLM_MODEL=ollama/mistral
# LLM_BASE_URL=http://localhost:11434
# LLM_PROVIDER=ollama
# LLM_NATIVE_STRUCTURED_OUTPUT=false

LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120

# =====================================================
# 数据库配置（Docker Compose 自动处理）
# 仅在使用外部 MySQL 时修改
# =====================================================
# DATABASE_URL=mysql+pymysql://prd_user:prd_password@mysql:3306/prd_agent?charset=utf8mb4
# TEST_DATABASE_URL=mysql+pymysql://prd_user:prd_password@mysql:3306/prd_agent_test?charset=utf8mb4

# MySQL 容器环境变量（docker-compose 使用）
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USER=prd_user
MYSQL_PASSWORD=prd_password

# =====================================================
# API 配置
# =====================================================
API_HOST=0.0.0.0
API_PORT=8000

# =====================================================
# Worker 配置
# =====================================================
WORKER_POLL_SECONDS=1

# =====================================================
# 工作流配置
# =====================================================
MAX_PRD_REVISION_ROUNDS=3

# =====================================================
# CrewAI 配置
# =====================================================
CREWAI_DISABLE_TELEMETRY=true
CREWAI_TRACING_ENABLED=false

# =====================================================
# 日志配置
# =====================================================
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
