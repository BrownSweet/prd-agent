# Model format: provider/model. Example: deepseek/deepseek-chat
LLM_MODEL=deepseek/deepseek-v4-pro
LLM_API_KEY=
# Optional for custom OpenAI-compatible endpoints.
LLM_BASE_URL=
LLM_PROVIDER=deepseek
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=120
# Optional. DeepSeek/Ollama default to false; native schema providers default to true.
LLM_NATIVE_STRUCTURED_OUTPUT=
API_HOST=127.0.0.1
API_PORT=8000
WORKER_POLL_SECONDS=1
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_READ_TIMEOUT_SECONDS=30
# The dialect is selected automatically from the URL. These SQLite defaults
# need no external database service and are recommended for local use.
DATABASE_URL=sqlite+pysqlite:///./data/prd_agent.db
TEST_DATABASE_URL=sqlite+pysqlite:///./data/prd_agent_test.db
# MySQL 8.0+ alternative:
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DATABASE?charset=utf8mb4
# TEST_DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DATABASE_test?charset=utf8mb4
MAX_PRD_REVISION_ROUNDS=3
CREWAI_DISABLE_TELEMETRY=true
CREWAI_TRACING_ENABLED=false

# Docker direct deployment (optional)
# APP_PORT=8080
# Keep the defaults below for SQLite, or point both values to an external MySQL.
# DOCKER_DATABASE_URL=sqlite+pysqlite:////app/data/prd_agent.db
# DOCKER_TEST_DATABASE_URL=sqlite+pysqlite:////app/data/prd_agent_test.db
